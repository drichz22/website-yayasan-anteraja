---
import BlogLayout from "../../features/blog/BlogLayout.astro";
import type { InferGetStaticParamsType } from "astro";
import { PortableText } from "astro-portabletext";
import { formatDate } from "../../shared/utils";
import { urlFor } from "../../features/blog/sanity/image";
import { getPost, getAllPosts } from "../../features/blog/sanity/queries";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
const { slug } = Astro.params as Params;

const post = await getPost(slug);
---

<BlogLayout title={post.title!}>
  <article class="min-h-screen bg-white py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <!-- Back Btn -->
      <div class="mb-6">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-brand-primary transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Kembali ke Blog
        </a>
      </div>

      <!-- Cover Image -->
      {post.mainImage ? (
        <img src={urlFor(post.mainImage).url()} alt="Cover image" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl mb-10"/>
      ) : (
        <div class="w-full h-[220px] sm:h-[320px] lg:h-[420px] bg-slate-200 rounded-2xl mb-10"/>
      )}

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-slate-900 mb-3">
        {post.title}
      </h1>

      <!-- Description -->
      {post.description && (
        <p class="text-lg sm:text-xl text-slate-600 leading-relaxed mb-6">
          {post.description}
        </p>
      )}

      <!-- Date -->
      <div class="flex items-center gap-3 text-sm text-slate-500 mb-10">
        <span>{formatDate(post._createdAt)}</span>
      </div>

      <!-- Content -->
      <div class="prose prose-lg max-w-none 
                  prose-slate 
                  prose-headings:font-bold
                  prose-a:text-brand-primary
                  prose-blockquote:border-l-brand-primary
                  prose-blockquote:text-slate-600
                  prose-img:rounded-xl
                  prose-img:shadow-md">
        <PortableText value={post.body} />
      </div>

    </div>
  </article>
</BlogLayout>
