---
import { Lightbulb, Target } from "lucide-astro";
import { Image } from "astro:assets";

import maksudTujuan from "../../../shared/assets/MaksudTujuan.jpg";

import program1 from "../../../shared/assets/Program-1.png";
import program2 from "../../../shared/assets/Program-2.jpeg";
---

<section id="aboutDetails" class="px-8 sm:px-16 md:px-12 py-24">
    <div class="flex flex-col gap-16">
        <!-- Visi & Misi -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch fade-section-right">
            <!-- Visi -->
            <div class="max-w-2xl rounded-lg shadow-md py-6 px-12 hover:scale-110 transition duration-700">
                <div class="flex flex-col">
                    <div class="inline-flex items-center gap-4 text-brand-secondary mb-4">
                        <Lightbulb class="w-7 h-7"/>
                        <h1 class="text-4xl font-bold">VISI</h1>
                    </div>
                    <p class="text-lg font-semibold">
                        Menjadi yayasan sosial yang optimal berkontribusi untuk negara Indonesia   
                    </p>
                </div>
            </div>
    
            <!-- Misi -->
            <div class="max-w-2xl rounded-lg shadow-md py-6 px-12 hover:scale-110 transition duration-700">
                <div class="flex flex-col">
                    <div class="inline-flex items-center gap-4 text-brand-secondary mb-4">
                        <Target class="w-7 h-7"/>
                        <h1 class="text-4xl font-bold">MISI</h1>
                    </div>
                    <p class="text-lg font-semibold">
                        Memberikan pelayanan dan menyelenggarakan kegiatan sosial
                    </p>
                </div>
            </div>
        </div>

        <!-- Peran -->
        <div class="flex flex-col gap-10">
            <h1 class="text-4xl font-bold text-brand-secondary fade-section-right opacity-0">MAKSUD DAN TUJUAN</h1>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <Image src={maksudTujuan} alt="Maksud dan Tujuan Illustration" class="w-full h-fit rounded-lg fade-section-right opacity-0"/>
                <p class="text-xl text-justify font-medium fade-section-right opacity-0">
                    Mendirikan badan hukum nirlaba diperuntukkan untuk mencapai tujuan sosial kemanusiaan seperti 
                    <strong class="text-brand-primary">membantu masyarakat yang terkena musibah/bencana</strong> 
                    serta mengatasi masalah sosial lainnya, dengan fokus utama
                    <strong class="text-brand-primary">meningkatkan kesejahteraan masyarakat tanpa mencari keuntungan</strong>
                </p>
            </div>
        </div>

        <!-- Program -->
        <div class="flex flex-col gap-16">
            <h1 class="text-4xl font-bold text-brand-secondary fade-section-right opacity-0">PROGRAM KAMI</h1>
            <!-- Rutin -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center fade-section-right opacity-0">
                <div class="rounded-lg shadow-md hover:scale-110 transition duration-700">
                    <div class="flex flex-col p-8">
                        <h2 class="text-3xl text-brand-primary font-bold mb-4">Kegiatan Rutin</h2>
                        <h3 class="text-lg font-medium mb-8">
                            Program kegiatan ini kami rutin laksanakan dalam memenuhi kewajiban kami sebagai sarana bantuan bagi masyarakat membutuhkan.
                        </h3>
                        <!-- Desc -->
                        <div class="text-gray-600">
                            <p class="mb-1">Program kami termasuk antara lain:</p>
                            <ul class="list-disc pl-5">
                                <li>Kunjungan ke panti asuhan</li>
                                <li>Kunjungan ke panti jompo</li>
                                <li>Donasi ke rumah/<span class="italic">shelter</span> hewan</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <Image src={program1} alt="Program Bantuan Kemanusiaan Illustration" class="w-full h-fit rounded-lg"/>
            </div>
            <!-- Tidak Rutin -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center fade-section-left opacity-0">
                <div class="rounded-lg shadow-md hover:scale-110 transition duration-700">
                    <div class="flex flex-col p-8">
                        <h2 class="text-3xl text-brand-primary font-bold mb-4">Kegiatan Tidak Rutin</h2>
                        <h3 class="text-lg font-medium mb-8">
                            Program ini kami laksanakan pada waktu tertentu karena skala bantuan yang besar dalam segi personel, waktu, dan biaya.
                        </h3>
                        <!-- Desc -->
                        <div class="text-gray-600">
                            <p class="mb-1">Program kami termasuk antara lain:</p>
                            <ul class="list-disc pl-5">
                                <li>Perbaikan sekolah yang rusak</li>
                                <li>Pembangunan/perbaikan jembatan desa/kampung</li>
                                <li>Pembuatan sumur di lokasi bencana/daerah sulit air bersih</li>
                                <li>Perbaikan tempat ibadah yang rusak</li>
                                <li>Pengadaan infrastruktur daerah bencana</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <Image src={program2} alt="Program Pendidikan Illustration" class="w-full aspect-[4/3] rounded-lg object-cover"/>
            </div>
        </div>
    </div>
</section>
