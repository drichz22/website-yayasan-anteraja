---
import { formatDate } from "../../../shared/utils";
import { urlFor } from "../sanity/image";
import type { Post } from "../sanity/queries";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="w-full bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col md:flex-row group hover:shadow-md transition-shadow">
  <div class="relative md:w-1/2">
    {
      post.mainImage ? (
        <img
          src={urlFor(post.mainImage).width(800).height(500).url()}
          alt={post.mainImage.alt || ""}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="w-full h-full bg-slate-800" />
      )
    }

    <div class="absolute top-4 left-4 flex gap-2">
      <span class="bg-cyan-600 text-white text-[11px] font-bold px-3 py-1 rounded-full uppercase">
        {post.category}
      </span>
    </div>
  </div>

  <div class="flex flex-col justify-between md:w-1/2 p-8">
    <div>
      <time datetime={post._createdAt} class="text-[12px] font-bold text-gray-400 uppercase tracking-widest">
        {formatDate(post._createdAt)}
      </time>

      <!-- TITLE -->
      <h2 class="text-3xl lg:text-5xl font-bold text-slate-800 leading-tight mt-2 mb-4 group-hover:text-[#0F7C9F] transition-colors">
        <a href={`/post/${post.slug.current}`}>
          {post.title}
        </a>
      </h2>

      <!-- DESCRIPTION -->
      <p class="text-gray-500 text-[15px] leading-relaxed line-clamp-3 lg:text-lg">
        {post.description}
      </p>
    </div>

    <!-- FOOTER -->
    <div class="flex items-center justify-between mt-6">
      <!-- READ MORE -->
      <a href={`/blog/${post.slug.current}`} class="text-sm font-bold text-[#0F7C9F] uppercase tracking-wide flex items-center gap-2">
        Baca Selengkapnya
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>
</article>
