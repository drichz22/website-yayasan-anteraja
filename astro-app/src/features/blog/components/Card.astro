---
import { formatDate } from "../../../shared/utils";
import { urlFor } from "../sanity/image";
import type { Post } from "../sanity/queries";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="relative flex flex-col w-full max-w-sm bg-white rounded-3xl border border-gray-100 shadow-[0_4px_20px_rgba(0,0,0,0.03)] overflow-hidden transition-shadow hover:shadow-[0_4px_25px_rgba(0,0,0,0.08)] group">
  <div class="relative">
    {
      post.mainImage ? (
        <img
          class="w-full h-56 object-cover"
          src={urlFor(post.mainImage).width(500).height(300).url()}
          alt={post.mainImage.alt || ""}
        />
      ) : (
        <div class="w-full h-56 bg-slate-800" />
      )
    }
    
    <span class="absolute top-4 right-4 bg-[#0F7C9F] text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">
      {post.category}
    </span>
  </div>

  <div class="flex flex-col flex-grow p-6">
    <time datetime={post._createdAt} class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-3">
      {formatDate(post._createdAt)}
    </time>
    
    <h3 class="text-[22px] font-bold text-slate-800 leading-[1.3] mb-3 group-hover:text-[#0F7C9F] transition-colors">
      <a href={`/blog/${post.slug.current}`} class="focus:outline-none">
        <span class="absolute inset-0" aria-hidden="true"></span>
        {post.title}
      </a>
    </h3>
    
    <p class="text-[14px] text-gray-500 line-clamp-2 mb-8 leading-relaxed">
      {post.description}
    </p>
    
    <div class="flex items-center justify-between mt-auto">
      <div class="text-[13px] font-bold text-[#0F7C9F] uppercase tracking-wide flex items-center gap-1.5">
        Selengkapnya
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </div>
    </div>
  </div>
</article>
