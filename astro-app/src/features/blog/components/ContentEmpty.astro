---
import { CircleOff } from "lucide-astro";
---

<div class="w-full flex flex-col items-center justify-center py-20 text-center">
  <!-- Icon -->
  <div class="w-20 h-20 rounded-full bg-gray-100 flex items-center justify-center mb-6">
    <CircleOff class="w-12 h-12"/>
  </div>

  <!-- Title -->
  <h3 class="text-xl font-semibold text-slate-800 mb-2">
    Belum Ada Artikel
  </h3>

  <!-- Description -->
  <p class="text-gray-500 max-w-md text-sm leading-relaxed">
    Saat ini belum terdapat artikel atau pembaruan yang tersedia. 
    Silakan cek kembali pada lain waktu ;)
  </p>
</div>
